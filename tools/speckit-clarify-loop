#!/usr/bin/env bash
# speckit-clarify-loop — automatiza o ciclo de clarificação do Spec Kit.
#
# Invariante: uma rodada = um processo `claude`. O término do processo É o
# `/clear`. Nunca usa --continue, --resume ou --dangerously-skip-permissions.
#
# Uso:
#   speckit-clarify-loop [--repo DIR] [--max-rounds N] [--allow-dirty] [--dry-run] [--self-test]
#
# Exit: 0 convergiu (frase seca ou estagnação), ou --self-test/--dry-run limpo
#       1 parada por guarda (teto de rodadas) ou aborto por erro
#       2 erro de uso ou de ambiente
#
# Ferramenta pessoal, instalada por cópia no PATH: não presume o ambiente de
# nenhum repo e checa as próprias dependências no arranque.
#
# Verificado em 2026-07-21 contra claude 2.1.216 e a skill speckit-clarify:
#   --dry-run em zion-test-build-prd (SPECIFY_FEATURE=006-code-interop) →
#   1 pergunta classificada, 0 yes injetados, spec intocado (188 → 188 linhas),
#   US$ 0,32, ~2 min. O stream confirma Skill + check-prerequisites.sh, ou seja:
#   `/speckit-clarify` como texto puro É despachado como slash command.
#   Nas duas execuções a skill alternou a língua dos marcadores (pt e en) — daí
#   a classificação bilíngue não ser luxo, e sim a diferença entre funcionar e
#   falhar de forma intermitente.
# Monitor verificado em 2026-07-21, em --dry-run e em três execuções:
#   TTY (zion-mermaid-editor-app, spec de 1081 linhas, US$ 1,99) → narração com
#     símbolos e cor, relógio de 00:03 a 05:16, 15 chamadas de ferramenta
#     resumidas em uma linha cada, 6 `pensando…` e nenhum par consecutivo, e a
#     pergunta inteira — tabela de 5 opções intacta — antes do aviso de dry-run;
#   | cat (zion-test-build-prd, 006-code-interop, US$ 0,30) → zero sequências
#     ANSI no stdout, e zero também no round-01.log;
#   --quiet (mesmo alvo, US$ 0,30) → tela só com cabeçalho de rodada e resumo,
#     e as 63 linhas de narração inteiras preservadas em round-01.log. É o que
#     faz do --quiet um modo sem perda: cala a tela, não a memória.
#   Nas três, o spec ficou intocado (delta +0).
# Reinstalar após editar:  install -m 755 tools/speckit-clarify-loop ~/.local/bin/
set -u

REPO="$PWD"
MAX_ROUNDS=10
ALLOW_DIRTY=0
DRY_RUN=0

# Teto de `yes` por rodada — espelha o limite de 5 perguntas da própria skill.
MAX_YES=5
# Rede contra um turno que trava sem emitir `result`. Não é flag: é salvaguarda.
#
# Era 900 s até 2026-07-21, quando uma rodada produtiva em zion-mermaid-editor-app
# — 3 perguntas respondidas, +57 linhas no spec — foi morta aos 898 s, no meio da
# integração da terceira resposta. É o pior momento possível: nenhuma guarda
# cobre o spec meio escrito por TERM, porque do lado de fora isso é
# indistinguível de um turno que travou.
#
# 1800 s cabe uma rodada de 5 perguntas num spec de ~1100 linhas, onde os turnos
# levaram 537 · 166 · 148 s. Continua sendo teto, não expectativa: turno que não
# emite `result` em 30 min está travado de verdade.
ROUND_TIMEOUT=1800
LOG_DIR=/tmp/speckit-clarify-loop

QUIET=0
MON_PROFILE=plain
MON_WIDTH=80
ROUND_LOG=""
LAST_KIND=""

die() { printf 'speckit-clarify-loop: %s\n' "$1" >&2; exit "${2:-2}"; }

usage() {
  cat >&2 <<'EOF'
uso: speckit-clarify-loop [--repo DIR] [--max-rounds N] [--allow-dirty] [--dry-run] [--quiet] [--self-test]

  --repo DIR       repo alvo (default: cwd)
  --max-rounds N   teto duro de rodadas (default: 10)
  --allow-dirty    dispensa a exigência de working tree limpo
  --dry-run        ensaio sem Edit/Write: para na 1ª pergunta sem responder, sem tocar o spec
  --quiet          cala a narração no stdout; o round-NN.log e o resumo continuam
  --self-test      roda os testes embutidos da classificação e sai
EOF
  exit 2
}

need_deps() {
  local missing="" c
  # `tput` fica de fora: já tem fallback para 80 e falta em contêiner enxuto —
  # exigi-lo negaria a ferramenta a quem só quer o perfil plain.
  for c in claude jq git mkfifo awk tail timeout fold sed; do
    command -v "$c" >/dev/null 2>&1 || missing="$missing $c"
  done
  [ -z "$missing" ] || die "dependência ausente:$missing — instale antes de rodar"
}

# --- Classificação do turno (função pura de texto) --------------------------
# Espelha speckit-clarify/SKILL.md: passo 5 (formato das perguntas), a regra de
# comportamento da frase seca e o último item do Completion Report.
#
# A ORDEM IMPORTA. O turno seco também é um Completion Report (traz "Suggested
# next command"), então loop-seco é testado primeiro. E, entre report e
# pergunta, report vem antes: classificar um report como pergunta injetaria
# `yes` numa rodada já encerrada; o inverso apenas gasta uma rodada a mais.
# A skill fala a língua do repo alvo: num projeto com CLAUDE.md em português ela
# traduz os próprios marcadores. Por isso cada sinal tem as duas formas — e os
# marcadores de pergunta param no `:`, sem o `**` de fechamento, porque em
# português o negrito envolve o rótulo inteiro (`**Recomendado: Opção B**`).
# E não basta a língua: o português flexiona. A skill concorda o adjetivo com o
# substantivo que vem depois — "Opção" é feminino, e ela escreve
# `**Recomendada:** Opção A`. Em 2026-07-21 isso custou uma rodada inteira
# (US$ 1,58) classificada como `indeterminada` com a pergunta na tela. Por isso
# cada marcador de pergunta tem as duas flexões, e não só as duas línguas.
# As frases de convergência ficam propositalmente longas: um falso positivo aqui
# encerra o loop achando que convergiu, que é a única falha silenciosa possível.
SIG_DRY='No critical ambiguities detected'
SIG_DRY_PT='Nenhuma ambiguidade crítica detectada'
SIG_COMPLETE='Suggested next command'
SIG_COMPLETE_PT='Próximo comando sugerido'
# Cinco capturas do mesmo fecho em 2026-07-21, todas em rodadas BOAS que o
# classificador jogou fora (US$ 8,12 + US$ 8,10 só nas duas últimas):
#
#   Suggested next command: `/speckit-plan`   ← constante, cobre-se por substring
#   ### Próximo passo
#   ### Próximo comando
#   **Próximo comando:** `/speckit-plan`      ← nem título é
#
# A quarta capura matou a hipótese de que "só o título é estável": a skill
# escreve o fecho como título OU como rótulo em negrito, e escolhe entre
# comando/passo. O que é estável é o par (marca de destaque no início da linha,
# palavra da família Próximo/Next). Daí a regex, que cobre as quatro formas e as
# que faltam do mesmo molde — sem cair na prosa, porque em prosa a frase aparece
# no MEIO da linha ("evita retrabalho no próximo passo do fluxo"), nunca ancorada
# depois de `#` ou `**`.
#
# Se um dia isto falhar de novo, o remédio não é mais uma alternância: é parar de
# adivinhar prosa e pedir à skill um marcador estável de fim de rodada.
SIG_NEXT_RE='^(#{1,4}[[:space:]]+|\*\*)(Próximo|Next)[[:space:]]+(comando|passo|command|step)'
SIG_MC='**Recommended:'
SIG_MC_PT='**Recomendado:'
SIG_MC_PT_F='**Recomendada:'
SIG_SHORT='**Suggested:'
SIG_SHORT_PT='**Sugerido:'
SIG_SHORT_PT_F='**Sugerida:'

has_sig() {  # texto em $1, sinais em $2..N → 0 se algum casar
  local txt="$1"; shift
  local s
  for s in "$@"; do
    printf '%s' "$txt" | grep -qF -- "$s" && return 0
  done
  return 1
}

has_re() {  # texto em $1, regex estendida em $2 → 0 se casar
  printf '%s' "${1:-}" | grep -qE -- "${2:-}"
}

classify() {  # texto do turno em $1 → rótulo em stdout
  local txt="${1:-}"
  if has_sig "$txt" "$SIG_DRY" "$SIG_DRY_PT"; then
    printf 'loop-seco\n'
  elif has_sig "$txt" "$SIG_COMPLETE" "$SIG_COMPLETE_PT" || has_re "$txt" "$SIG_NEXT_RE"; then
    printf 'rodada-completa\n'
  elif has_sig "$txt" "$SIG_MC" "$SIG_MC_PT" "$SIG_MC_PT_F" \
                      "$SIG_SHORT" "$SIG_SHORT_PT" "$SIG_SHORT_PT_F"; then
    printf 'pergunta-pendente\n'
  else
    printf 'indeterminada\n'
  fi
}

# --- Leitura do rate limit (função pura de texto) ---------------------------
# A guarda original abortava a rodada em QUALQUER status != "allowed". Em
# 2026-07-21, em zion-mermaid-editor-app, chegou um `allowed_warning`
# (utilization 0.9, surpassedThreshold 0.9): a requisição foi PERMITIDA, e o
# campo é só o aviso de que a janela de 5h se aproxima do teto. A rodada foi
# abortada com 1 yes já integrado e US$ 2,40 pagos — e, pior, o corte caiu logo
# depois de três `Edit` em voo, que é o cenário que a própria guarda existe para
# evitar. (O turno sobreviveu porque o `break` só fecha o stdin, e o claude ainda
# fecha o turno corrente; foi sorte de temporização, não desenho.)
#
# A família permitida é `allowed*`: o aviso é um estado de permissão, não de
# recusa. Status desconhecido continua fatal de propósito — não saber se a cota
# acabou é razão para parar, ao contrário de saber que ela ainda não acabou.
ratelimit_fatal() {  # status → 0 se a rodada deve abortar
  case "${1:-?}" in
    allowed|allowed_*) return 1 ;;
    *)                 return 0 ;;
  esac
}

# --- Leitura das negações de permissão (funções puras de texto) -------------
# A guarda original abortava a rodada diante de QUALQUER permission_denial, com
# a justificativa de que a rodada "gravaria spec pela metade". A justificativa
# vale para a família que escreve: negar um `Edit` no meio de uma sequência de
# edições deixa o spec com metade das mudanças aplicadas. Não vale para leitura.
#
# Em 2026-07-21 isso custou duas rodadas inteiras (US$ 1,75 e US$ 1,79) em
# zion-mermaid-editor-app: o que foi negado era um `grep` de listar cabeçalhos,
# a skill contornou, a rodada terminou com a pergunta completa e `is_error`
# false — e o script jogou tudo fora assim mesmo.
#
# `Bash` fica FORA da lista de mutantes de propósito, e a razão merece estar
# escrita: uma chamada negada não executou, então ela própria não gravou nada. O
# risco de spec meio escrito nasce da sequência de `Edit` que a skill usa para
# atualizar o spec, e é essa sequência que a guarda protege.
MUTANTES='Edit Write MultiEdit NotebookEdit'

# O `total_cost_usd` do evento `result` é ACUMULADO da sessão, não a parcela
# daquele turno — numa rodada com 3 `yes` os quatro results trouxeram
# 2,27 · 3,77 · 4,59 · 5,10, sempre crescendo, enquanto `usage.output_tokens`
# ia de 36880 a 3195. Somar os quatro dava US$ 15,74 para uma rodada que custou
# US$ 5,10: o triplo. Por isso o custo da rodada é o ÚLTIMO valor, não a soma.
# Entre rodadas a soma continua correta — cada rodada é um processo e uma sessão
# nova, por invariante. (A documentação oficial não declara essa semântica; ela
# vem da evidência do stream, e o campo tem histórico de valores inflados no
# issue anthropics/claude-code#53371.)
pick_cost() {  # linha-jsonl  custo-atual → custo da rodada
  local c
  c="$(printf '%s' "${1:-}" | jq -r '.total_cost_usd // empty' 2>/dev/null)"
  case "$c" in
    ''|null) printf '%s' "${2:-0}" ;;
    *)       printf '%s' "$c" ;;
  esac
  return 0
}

denied_tools() {  # linha-jsonl → nomes das ferramentas negadas, separados por espaço
  printf '%s' "${1:-}" \
    | jq -r '[(.permission_denials // [])[] | .tool_name // "?"] | join(" ")' 2>/dev/null
  return 0
}

mutating_only() {  # lista de nomes → só as que escrevem, na mesma ordem
  local out="" t m
  for t in ${1:-}; do
    for m in $MUTANTES; do
      if [ "$t" = "$m" ]; then out="$out $t"; break; fi
    done
  done
  printf '%s' "${out# }"
  return 0
}

# --- Monitor: primitivas de formatação -------------------------------------
# Dois perfis. `tty` usa símbolos e ANSI; `plain` usa rótulos ASCII e nada de
# escape — porque o round-NN.log tem que continuar legível seis meses depois,
# e arquivo com sequência ANSI dentro é arquivo que ninguém relê.
MON_IND='         '   # 9 colunas: a indentação de continuação, nos dois perfis

mon_marker() {  # perfil kind → marcador (no perfil plain, já com 8 colunas)
  case "${1:-}:${2:-}" in
    tty:tool)       printf '⚙' ;;
    tty:text)       printf '◆' ;;
    tty:you)        printf '▸' ;;
    tty:thinking)   printf '·' ;;
    tty:ok)         printf '✓' ;;
    tty:warn)       printf '⚠' ;;
    plain:tool)     printf '[tool]  ' ;;
    plain:text)     printf '[claude]' ;;
    plain:you)      printf '[você]  ' ;;
    plain:thinking) printf '[...]   ' ;;
    plain:ok)       printf '[ok]    ' ;;
    plain:warn)     printf '[!]     ' ;;
    *)              printf '?' ;;
  esac
}

# Colunas consumidas por "  CLOCK  MARCADOR  ": 2+5+2+largura(marcador)+2.
mon_prefix() { case "${1:-}" in tty) printf '12' ;; *) printf '19' ;; esac; }

mon_head() {  # clock marcador corpo
  printf '  %s  %s  %s\n' "${1:-}" "${2:-}" "${3:-}"
}

mon_paint() {  # perfil cor texto
  if [ "${1:-}" != tty ]; then printf '%s' "${3:-}"; return 0; fi
  local c
  case "${2:-}" in
    dim)  c=$'\033[2m' ;;
    bold) c=$'\033[1m' ;;
    red)  c=$'\033[31m' ;;
    *)    printf '%s' "${3:-}"; return 0 ;;
  esac
  printf '%s%s\033[0m' "$c" "${3:-}"
}

mon_trunc() {  # texto largura
  local t="${1:-}" w="${2:-80}"
  [ "$w" -ge 8 ] || w=8
  if [ "${#t}" -le "$w" ]; then printf '%s' "$t"; return 0; fi
  printf '%s…' "${t:0:$((w - 1))}"
}

# Dobra a prosa e indenta em 9 colunas. Tabelas markdown e cercas de código
# escapam da dobra de propósito: quebrar a tabela de opções destrói exatamente
# a informação que se quer ler. Se estourar a largura, estoura.
mon_fold() {  # largura total; stdin → stdout
  local w=$(( ${1:-80} - 9 ))
  [ "$w" -ge 20 ] || w=20
  local l
  while IFS= read -r l || [ -n "$l" ]; do
    case "$l" in
      '')        printf '\n' ;;
      '|'*|'```'*) printf '%s%s\n' "$MON_IND" "$l" ;;
      *)         printf '%s\n' "$l" | fold -s -w "$w" \
                   | sed -e "s/^/$MON_IND/" -e 's/[[:space:]]*$//' ;;
    esac
  done
  return 0
}

# Resumo de um tool_use: comando para Bash, basename para quem tem file_path,
# e um genérico de primeira chave para o resto (nenhuma ferramenta fica muda).
# Só o primeiro tool_use da linha é resumido — perder uma chamada de ferramenta
# é aceitável; perder prosa não é, e por isso a prosa tem precedência em
# event_kind.
tool_summary() {  # linha-jsonl → NOME<TAB>RESUMO
  printf '%s' "${1:-}" | jq -r '
    ([.message.content[]? | select(.type=="tool_use")] | first) as $t
    | if $t == null then empty else
        ($t.input // {}) as $i
        | [ ($t.name // "?"),
            ( if   $i.command   then ($i.command | gsub("\\s+"; " "))
              elif $i.file_path then ($i.file_path | split("/") | last)
              elif $i.pattern   then $i.pattern
              else (($i | keys | first) as $k
                    | if $k == null then "" else "\($k)=\($i[$k] | tostring)" end)
              end ) ]
        | @tsv
      end' 2>/dev/null
  return 0
}

# --- Monitor: leitura de eventos -------------------------------------------
# Traduz uma linha do stream JSONL num rótulo. Função pura: sem I/O além do
# stdout, sem estado global. Qualquer linha que o jq não digira cai em
# `nothing` — o monitor é aditivo e jamais derruba a rodada.
#
# Precedência dentro de uma linha `assistant`: text > tool_use > thinking.
# No stream observado toda linha trazia um único bloco, mas se a API um dia
# agrupar blocos, perder a prosa seria a única falha inaceitável.
event_kind() {
  local line="${1:-}" typ types st
  typ="$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)"
  case "$typ" in
    result)
      printf 'result\n'; return 0 ;;
    rate_limit_event)
      st="$(printf '%s' "$line" | jq -r '.rate_limit_info.status // "?"' 2>/dev/null)"
      if [ "$st" = "allowed" ]; then printf 'nothing\n'; else printf 'ratelimit\n'; fi
      return 0 ;;
    assistant)
      types="$(printf '%s' "$line" | jq -r '[.message.content[]?.type] | join(" ")' 2>/dev/null)"
      case " $types " in
        *' text '*)     printf 'text\n' ;;
        *' tool_use '*) printf 'tool\n' ;;
        *' thinking '*) printf 'thinking\n' ;;
        *)              printf 'nothing\n' ;;
      esac
      return 0 ;;
    *)
      printf 'nothing\n'; return 0 ;;
  esac
}

# Suprime `pensando…` repetido. Note que o kind anterior é o último kind
# EFETIVO — eventos que não rendem linha (system/*, tool_result) não o mexem,
# de modo que thinking · ruído · thinking conta como um só arroubo de reflexão.
dedup_kind() {  # kind-anterior  kind → kind efetivo
  if [ "${2:-}" = thinking ] && [ "${1:-}" = thinking ]; then
    printf 'nothing\n'
  else
    printf '%s\n' "${2:-nothing}"
  fi
}

# --- Monitor: renderização --------------------------------------------------
# (perfil, largura, clock, kind, linha) → narração. Pura: o relógio chega
# pronto, nada de estado mutável. É a única função que sabe como a saída se
# parece, e por isso a única que precisa mudar se a apresentação mudar.
render_line() {  # perfil largura clock kind linha
  local p="${1:-plain}" w="${2:-80}" clock="${3:-00:00}" kind="${4:-nothing}" line="${5:-}"
  local body prefix tsv name summary st

  prefix="$(mon_prefix "$p")"

  case "$kind" in
    thinking)
      mon_head "$clock" "$(mon_marker "$p" thinking)" "$(mon_paint "$p" dim 'pensando…')"
      ;;
    tool)
      tsv="$(tool_summary "$line")"
      [ -n "$tsv" ] || return 0
      name="${tsv%%$'\t'*}"
      summary="${tsv#*$'\t'}"
      [ "$summary" != "$tsv" ] || summary=""
      body="$(printf '%-8s %s' "$name" "$summary")"
      body="$(mon_trunc "$body" $(( w - prefix )))"
      mon_head "$clock" "$(mon_marker "$p" tool)" "$(mon_paint "$p" dim "$body")"
      ;;
    text)
      mon_head "$clock" "$(mon_marker "$p" text)" 'claude'
      printf '%s' "$line" \
        | jq -r '[.message.content[]? | select(.type=="text") | .text] | join("\n\n")' 2>/dev/null \
        | mon_fold "$w"
      ;;
    ratelimit)
      st="$(printf '%s' "$line" | jq -r '.rate_limit_info.status // "?"' 2>/dev/null)"
      mon_head "$clock" "$(mon_marker "$p" warn)" "$(mon_paint "$p" red "rate limit: $st")"
      ;;
    *)
      # nothing e result não rendem linha. O rodapé da rodada é emitido pelo
      # motor (emit_note), que é quem conhece o contador de yes e o delta do
      # spec; e a prosa do `.result` é a mesma do último bloco assistant, que
      # já foi impressa — reimprimi-la duplicaria a pergunta inteira.
      return 0
      ;;
  esac
  return 0
}

# --- Monitor: cola com estado -----------------------------------------------
# O único lugar do monitor que fala com o mundo: relógio, destinos e a memória
# do último kind. As três funções acima permanecem puras justamente porque tudo
# que é impuro está aqui.

mon_setup() {  # decide perfil e largura, uma vez, no arranque
  if [ -t 1 ]; then
    MON_PROFILE=tty
    MON_WIDTH="$(tput cols 2>/dev/null || printf '80')"
    case "$MON_WIDTH" in ''|*[!0-9]*) MON_WIDTH=80 ;; esac
    [ "$MON_WIDTH" -le 100 ] || MON_WIDTH=100
    [ "$MON_WIDTH" -ge 40 ] || MON_WIDTH=40
  else
    MON_PROFILE=plain
    MON_WIDTH=80
  fi
  return 0
}

mon_clock() { printf '%02d:%02d' $(( SECONDS / 60 )) $(( SECONDS % 60 )); }

mon_round_start() {  # caminho do round-NN.log
  ROUND_LOG="${1:-}"
  LAST_KIND=""
  SECONDS=0
  [ -z "$ROUND_LOG" ] || : > "$ROUND_LOG"
  return 0
}

# O log em arquivo recebe SEMPRE perfil plain com largura 80 — daí a prosa ser
# renderizada duas vezes no TTY. É baratíssimo, e evita ter que arrancar ANSI
# com sed no caminho de escrita.
emit_event() {  # linha-jsonl
  local line="${1:-}" kind clock
  kind="$(event_kind "$line")"
  kind="$(dedup_kind "$LAST_KIND" "$kind")"
  [ "$kind" = nothing ] && return 0
  LAST_KIND="$kind"
  clock="$(mon_clock)"
  [ "$QUIET" -eq 1 ] || render_line "$MON_PROFILE" "$MON_WIDTH" "$clock" "$kind" "$line"
  [ -z "$ROUND_LOG" ] || render_line plain 80 "$clock" "$kind" "$line" >> "$ROUND_LOG"
  return 0
}

# Linhas que nascem no motor, não no stream: o eco do `yes`, o rodapé da
# rodada, os avisos de aborto.
emit_note() {  # kind texto
  local kind="${1:-text}" text="${2:-}" clock color
  case "$kind" in
    you)  color=bold ;;
    warn) color=red ;;
    *)    color=none ;;
  esac
  clock="$(mon_clock)"
  [ "$QUIET" -eq 1 ] || \
    mon_head "$clock" "$(mon_marker "$MON_PROFILE" "$kind")" "$(mon_paint "$MON_PROFILE" "$color" "$text")"
  [ -z "$ROUND_LOG" ] || \
    mon_head "$clock" "$(mon_marker plain "$kind")" "$text" >> "$ROUND_LOG"
  return 0
}

# Estrutura (cabeçalho de rodada): sem relógio, e sobrevive ao --quiet — é o
# mínimo que diz "ainda estou vivo" quando a narração está calada.
emit_rule() {  # texto
  printf '%s\n' "${1:-}"
  [ -z "$ROUND_LOG" ] || printf '%s\n' "${1:-}" >> "$ROUND_LOG"
  return 0
}

# --- Preflight -------------------------------------------------------------
# Resolve o spec alvo pela MESMA fonte que a skill usa (passo 1), para que
# script e skill nunca divirjam de arquivo.
SPEC=""
WORK=""

preflight() {
  [ -d "$REPO" ] || die "repo não encontrado: $REPO"
  REPO="$(cd "$REPO" && pwd)"
  [ -d "$REPO/.specify" ] || die "não parece um repo Spec Kit (sem .specify/): $REPO"

  local prereq="$REPO/.specify/scripts/bash/check-prerequisites.sh"
  [ -f "$prereq" ] || die "check-prerequisites.sh ausente em $REPO/.specify/scripts/bash/"

  git -C "$REPO" rev-parse --git-dir >/dev/null 2>&1 \
    || die "repo alvo não é um repositório git: $REPO"
  if [ "$ALLOW_DIRTY" -eq 0 ] && [ -n "$(git -C "$REPO" status --porcelain)" ]; then
    die "working tree sujo em $REPO — commite ou descarte antes (ou passe --allow-dirty)"
  fi

  local json
  json="$(cd "$REPO" && bash "$prereq" --json --paths-only 2>&1)" \
    || die "check-prerequisites.sh falhou: $json"
  SPEC="$(printf '%s' "$json" | jq -r '.FEATURE_SPEC // empty' 2>/dev/null)" \
    || die "saída do check-prerequisites.sh não é JSON: $json"
  [ -n "$SPEC" ] || die "check-prerequisites.sh não devolveu FEATURE_SPEC: $json"
  [ -f "$SPEC" ] || die "spec alvo não existe: $SPEC"

  mkdir -p "$LOG_DIR" || die "não consegui criar $LOG_DIR"
  rm -f "$LOG_DIR"/round-*.jsonl "$LOG_DIR"/round-*.jsonl.err "$LOG_DIR"/round-*.log
  WORK="$(mktemp -d "${TMPDIR:-/tmp}/speckit-clarify-loop.XXXXXX")" \
    || die "não consegui criar diretório de trabalho"
}

cleanup() { [ -n "$WORK" ] && rm -rf "$WORK"; }
trap cleanup EXIT

spec_hash()  { git hash-object "$SPEC"; }
spec_lines() { wc -l < "$SPEC" | tr -d ' '; }

# --- Motor de uma rodada ----------------------------------------------------
ROUND_OUTCOME=""
ROUND_YES=0
ROUND_COST=0
ROUND_ABORT=""

send_user() {  # texto → uma mensagem de usuário JSONL no fd 3
  jq -cn --arg t "$1" \
    '{type:"user",message:{role:"user",content:[{type:"text",text:$t}]}}' >&3
}

add_cost() {  # a b → a+b com 6 casas
  awk -v a="$1" -v b="$2" 'BEGIN{printf "%.6f", a+b}'
}

run_round() {  # número da rodada em $1
  local n="$1"
  local tag; tag="$(printf '%02d' "$n")"
  local log="$LOG_DIR/round-$tag.jsonl"
  local err="$log.err"
  local in="$WORK/in-$n.fifo"

  ROUND_OUTCOME=""; ROUND_YES=0; ROUND_COST=0; ROUND_ABORT=""

  mkfifo "$in" || { ROUND_OUTCOME=aborto; ROUND_ABORT="mkfifo falhou"; return; }
  : > "$log"; : > "$err"

  # Permissões mínimas: acceptEdits sozinho não basta porque a skill roda o
  # check-prerequisites.sh via Bash, e prompt de permissão em modo não
  # interativo vira negação silenciosa. Em --dry-run, Edit/Write saem de cena.
  local -a args=(
    -p
    --input-format stream-json
    --output-format stream-json
    --verbose
    --permission-mode acceptEdits
    --allowedTools 'Bash(.specify/scripts/bash/check-prerequisites.sh*)'
  )
  if [ "$DRY_RUN" -eq 1 ]; then
    args+=( --disallowedTools Edit Write MultiEdit NotebookEdit )
  fi

  # A salvaguarda de tempo é o próprio `timeout` embrulhando o claude, e não um
  # watchdog em subshell: `kill` no subshell não mata o `sleep` lá dentro, que
  # sobrevive órfão segurando o stdout herdado — e trava por 15 min qualquer
  # `speckit-clarify-loop | tee`. Com `timeout` não há filho para vazar.
  ( cd "$REPO" && exec timeout -s TERM "$ROUND_TIMEOUT" claude "${args[@]}" ) \
    < "$in" > "$log" 2> "$err" &
  local cpid=$!

  exec 3<> "$in"   # read-write: nunca bloqueia, mesmo se o claude já morreu

  send_user '/speckit-clarify'

  local line typ status iserr denied mutantes txt
  while IFS= read -r line; do
    emit_event "$line"
    typ="$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)" || continue

    if [ "$typ" = "rate_limit_event" ]; then
      status="$(printf '%s' "$line" | jq -r '.rate_limit_info.status // "?"')"
      if ratelimit_fatal "$status"; then
        ROUND_OUTCOME=aborto
        ROUND_ABORT="rate limit com status=$status — cota esgotada, não insisto"
        break
      fi
      continue
    fi

    [ "$typ" = "result" ] || continue

    iserr="$(printf '%s' "$line" | jq -r '.is_error // false')"
    denied="$(denied_tools "$line")"
    mutantes="$(mutating_only "$denied")"
    ROUND_COST="$(pick_cost "$line" "$ROUND_COST")"

    if [ "$iserr" = "true" ]; then
      ROUND_OUTCOME=aborto; ROUND_ABORT="result com is_error=true (ver $log)"; break
    fi
    # Em --dry-run a negação de Edit/Write é esperada: é o próprio mecanismo.
    if [ -n "$mutantes" ] && [ "$DRY_RUN" -eq 0 ]; then
      ROUND_OUTCOME=aborto
      ROUND_ABORT="permissão negada em ferramenta que escreve ($mutantes) — rodada gravaria spec pela metade"
      break
    fi
    # Negação de leitura não ameaça o spec: a chamada nem executou. Narra e segue.
    [ -z "$denied" ] || [ -n "$mutantes" ] \
      || emit_note warn "permissão negada, rodada segue: $denied"

    txt="$(printf '%s' "$line" | jq -r '.result // ""')"
    case "$(classify "$txt")" in
      pergunta-pendente)
        # Em --dry-run paramos na primeira pergunta, sem responder. Sem
        # Edit/Write a skill não consegue gravar a resposta e se debate em
        # contornos via Bash até pedir permissão: responder ali só queima cota
        # num turno que nunca convergiria. O que o modo prova é o que importa —
        # preflight, spec alvo e classificação — com o spec intocado.
        if [ "$DRY_RUN" -eq 1 ]; then
          ROUND_OUTCOME=dry-pergunta
          emit_note warn 'dry-run: pergunta detectada, não respondo'
          break
        fi
        if [ "$ROUND_YES" -ge "$MAX_YES" ]; then
          ROUND_OUTCOME=aborto
          ROUND_ABORT="teto de $MAX_YES yes estourado na rodada $n"
          break
        fi
        ROUND_YES=$((ROUND_YES + 1))
        emit_note you "$(printf '%-24s (pergunta %d/%d)' 'yes' "$ROUND_YES" "$MAX_YES")"
        send_user 'yes'
        ;;
      loop-seco)       ROUND_OUTCOME=loop-seco;       break ;;
      rodada-completa) ROUND_OUTCOME=rodada-completa; break ;;
      indeterminada)
        ROUND_OUTCOME=indeterminada
        emit_note warn "turno indeterminado — stream em $log"
        break
        ;;
    esac
  done < <(exec 3>&-; tail -n +1 -f --pid="$cpid" --sleep-interval=0.2 "$log")

  exec 3>&-              # fecha o stdin do claude → o processo sai → é o /clear
  wait "$cpid" 2>/dev/null
  rm -f "$in"

  # Stream terminou sem classificar nada: o processo caiu.
  if [ -z "$ROUND_OUTCOME" ]; then
    ROUND_OUTCOME=aborto
    ROUND_ABORT="o processo claude terminou sem emitir turno classificável (ver $err)"
  fi

  [ "$ROUND_OUTCOME" != aborto ] || emit_note warn "aborto: $ROUND_ABORT"
}

# --- Driver do loop ---------------------------------------------------------
main_loop() {
  local round=0 same=0 prev_hash cur_hash
  local total_yes=0 total_cost=0 yes_log="" stop_reason="" rc=1
  local start_lines end_lines delta tag rule_pad

  start_lines="$(spec_lines)"
  printf 'speckit-clarify-loop: %s\n  spec: %s (%s linhas)\n' \
    "$REPO" "$SPEC" "$start_lines"
  [ "$DRY_RUN" -eq 1 ] && printf '  modo: --dry-run (para na 1ª pergunta, sem Edit/Write)\n'

  while [ "$round" -lt "$MAX_ROUNDS" ]; do
    round=$((round + 1))
    tag="$(printf '%02d' "$round")"
    prev_hash="$(spec_hash)"
    # mon_round_start fica aqui, e não dentro de run_round: main_loop já tem o
    # `tag`, e é o único ponto em que o cabeçalho da rodada nasce dentro do log
    # daquela rodada — em run_round ele cairia no log da rodada anterior.
    mon_round_start "$LOG_DIR/round-$tag.log"
    printf -v rule_pad '%*s' "$(( MON_WIDTH > 30 ? MON_WIDTH - 20 : 10 ))" ''
    emit_rule ''
    emit_rule "$(printf '── rodada %s/%s %s' "$tag" "$MAX_ROUNDS" "${rule_pad// /─}")"

    run_round "$round"

    total_yes=$((total_yes + ROUND_YES))
    total_cost="$(add_cost "$total_cost" "$ROUND_COST")"
    yes_log="$yes_log r$tag=$ROUND_YES"
    cur_hash="$(spec_hash)"
    emit_note ok "$(printf '%s · %d yes · US$ %s' "$ROUND_OUTCOME" "$ROUND_YES" "$ROUND_COST")"

    case "$ROUND_OUTCOME" in
      loop-seco)
        stop_reason="convergiu — a skill declarou não haver ambiguidade crítica"; rc=0; break ;;
      aborto)
        stop_reason="aborto na rodada $tag — $ROUND_ABORT"; rc=1; break ;;
      indeterminada)
        stop_reason="turno indeterminado na rodada $tag (stream: $LOG_DIR/round-$tag.jsonl)"
        rc=1; break ;;
    esac

    # O --dry-run vive de uma rodada só: a checagem de hash é o que prova que o
    # ensaio não escreveu nada. Se escreveu, o modo perdeu a razão de existir.
    if [ "$DRY_RUN" -eq 1 ]; then
      if [ "$ROUND_OUTCOME" = "dry-pergunta" ]; then
        stop_reason="--dry-run: 1 pergunta classificada, nada gravado"
      else
        stop_reason="--dry-run: rodada encerrada em $ROUND_OUTCOME sem perguntas, nada gravado"
      fi
      rc=0
      if [ "$cur_hash" != "$prev_hash" ]; then
        stop_reason="--dry-run ALTEROU o spec (hash mudou) — investigue antes de confiar no modo"
        rc=1
      fi
      break
    fi

    if [ "$cur_hash" = "$prev_hash" ]; then
      same=$((same + 1))
      if [ "$same" -ge 2 ]; then
        stop_reason="convergiu por estagnação — 2 rodadas seguidas sem alterar o spec"
        rc=0; break
      fi
    else
      same=0
    fi
  done

  if [ -z "$stop_reason" ]; then
    stop_reason="teto de rodadas atingido ($MAX_ROUNDS) sem convergir"
    rc=1
  fi

  end_lines="$(spec_lines)"
  delta=$((end_lines - start_lines))
  printf '\n—— resumo ——\n'
  printf 'repo:     %s\n' "$REPO"
  printf 'spec:     %s\n' "$SPEC"
  printf 'rodadas:  %s\n' "$round"
  printf 'yes:      %s (%s)\n' "$total_yes" "${yes_log# }"
  printf 'custo:    US$ %s\n' "$total_cost"
  printf 'spec:     %s → %s linhas (delta %+d)\n' "$start_lines" "$end_lines" "$delta"
  printf 'streams:  %s/round-*.jsonl\n' "$LOG_DIR"
  printf 'parada:   %s\n' "$stop_reason"
  printf '\nreverter: git -C %s checkout -- %s\n' "$REPO" "$SPEC"

  return "$rc"
}

