ST_FAIL=0
# Contador de casos: cresce sozinho a cada asserção. O literal que ele substitui
# era uma segunda verdade sobre o tamanho da suíte — acrescentar um teste e
# esquecer de somar 1 não deixava rastro nenhum.
ST_COUNT=0
assert_out() {  # descrição  esperado  comando…
  local desc="$1" want="$2"; shift 2
  ST_COUNT=$((ST_COUNT + 1))
  local got; got="$("$@")"
  if [ "$got" = "$want" ]; then
    printf 'ok: %s\n' "$desc"
  else
    printf 'FALHOU: %s\n  esperado: [%s]\n  veio:     [%s]\n' "$desc" "$want" "$got"
    ST_FAIL=1
  fi
}

# Adaptador de teste: mon_fold é filtro de stdin, e assert_out só sabe chamar
# comando com argumentos.
mon_fold_str() { printf '%s\n' "$2" | mon_fold "$1"; }

# Adaptador de teste, irmão do mon_fold_str: ratelimit_fatal responde por status
# de saída, e assert_out só sabe comparar stdout.
fatal_str() { if ratelimit_fatal "${1:-}"; then printf 'sim'; else printf 'nao'; fi; }

# Terceiro adaptador da família: leaked_sentinel responde por status de saída, e
# assert_out só sabe comparar stdout.
leak_str() { if leaked_sentinel "${1:-}" "${2:-}"; then printf 'sim'; else printf 'nao'; fi; }

# Irmão do assert_out para as funções COM estado. A diferença é só a captura:
# `$(...)` roda em subshell, e a atribuição de LAST_KIND dentro de emit_event
# morreria ali — a supressão de thinking nunca seria exercitada de verdade.
# Redirecionar para arquivo mantém a chamada no shell corrente.
assert_emit() {  # descrição  esperado  comando…
  local desc="$1" want="$2"; shift 2
  ST_COUNT=$((ST_COUNT + 1))
  local tmp got
  tmp="$(mktemp "${TMPDIR:-/tmp}/speckit-clarify-loop-st.XXXXXX")"
  SECONDS=0
  "$@" > "$tmp"
  got="$(cat "$tmp")"; rm -f "$tmp"
  if [ "$got" = "$want" ]; then
    printf 'ok: %s\n' "$desc"
  else
    printf 'FALHOU: %s\n  esperado: [%s]\n  veio:     [%s]\n' "$desc" "$want" "$got"
    ST_FAIL=1
  fi
}

