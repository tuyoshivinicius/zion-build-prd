#!/usr/bin/env bash
# speckit-e2e-loop — orquestra a spec inteira do backlog até "pronta para codar",
# encadeando os 8 passos que cruzam a fronteira harness↔Spec Kit, cada um em
# sessão limpa. Irmã do speckit-clarify-loop; reusa a invariante e o padrão dele.
#
# Invariante: um passo = um processo `claude`. O término do processo É o `/clear`.
# Nunca usa --continue, --resume ou --dangerously-skip-permissions.
#
# Passos: specify-prompt → specify → clarify → plan-prompt → plan → tasks →
#         analyze → trace. Hands-off até bater num achado curado (vazamento de
#         stack, analyze crítico, clarify que não convergiu, guarda de suficiência
#         do plan-prompt), e aí para e entrega ao humano.
#
# Uso:
#   speckit-e2e-loop <slug> [--repo DIR] [--from PASSO] [--max-cost USD]
#                           [--allow-dirty] [--dry-run] [--quiet] [--self-test]
#
# Exit: 0 completou até o trace (ou --self-test/--dry-run limpo)
#       1 parou antes do trace (parada-por-achado ou aborto)
#       2 erro de uso ou de ambiente
#
# Ferramenta pessoal, fora do canon do zion-build-prd. Checa as próprias
# dependências no arranque.
# Reinstalar após editar:  install -m 755 tools/speckit-e2e-loop ~/.local/bin/
set -u

SLUG=""
REPO="$PWD"
FROM=""
MAX_COST=""
ALLOW_DIRTY=0
DRY_RUN=0
QUIET=0
# Monitor (copiado do speckit-clarify-loop). Perfil/largura decididos no arranque
# por mon_setup; STEP_LOG é o log plain por passo; LAST_KIND dedup do thinking.
MON_PROFILE=plain
MON_WIDTH=80
STEP_LOG=""
LAST_KIND=""

# Teto de "confirma, siga" por sessão de ponte — nunca fica pendurado num gate
# que se repete (design §Sessão e extração).
GATE_MAX=3
# Rede contra um passo que trava sem emitir `result`. Herdado do clarify-loop
# (speckit-clarify-loop:133): 1800s é teto, não expectativa.
STEP_TIMEOUT=1800

LOG_ROOT=/tmp/speckit-e2e-loop
STATE_DIR=""     # /tmp/speckit-e2e-loop/<slug> — definido no preflight
STATE_FILE=""    # $STATE_DIR/state
NEXT_FILE=""     # $STATE_DIR/next.txt
SIGNAL_FILE=""   # $STATE_DIR/signal.txt
CHECK_PRD=""     # resolvido na Task 5

die() { printf 'speckit-e2e-loop: %s\n' "$1" >&2; exit "${2:-2}"; }

usage() {
  cat >&2 <<'EOF'
uso: speckit-e2e-loop <slug> [--repo DIR] [--from PASSO] [--max-cost USD]
                            [--allow-dirty] [--dry-run] [--quiet] [--self-test]

  <slug>           slug da spec no docs/backlog.md (obrigatório)
  --repo DIR       repo alvo (default: cwd)
  --from PASSO     retoma de um passo, forçando re-execução e limpando os a jusante
                   ∈ {specify-prompt, specify, clarify, plan-prompt, plan, tasks, analyze, trace}
  --max-cost USD   teto global de custo somado; estourou, aborta
  --allow-dirty    dispensa a exigência de working tree limpo
  --dry-run        roda só o passo 1 (specify-prompt) sem Edit/Write; reporta o que capturaria
  --quiet          cala a narração no stdout; os logs por passo e o resumo continuam
  --self-test      roda os testes embutidos do núcleo puro e sai
EOF
  exit 2
}

need_deps() {
  local missing="" c
  for c in claude jq git mkfifo awk tail timeout sed grep cat head cp date mktemp; do
    command -v "$c" >/dev/null 2>&1 || missing="$missing $c"
  done
  command -v speckit-clarify-loop >/dev/null 2>&1 \
    || missing="$missing speckit-clarify-loop"
  [ -z "$missing" ] || die "dependência ausente:$missing — instale antes de rodar"
}

# --- Máquina de estados dos 8 passos (funções puras) -----------------------
# A ordem canônica. Uma verdade só: --from, retomada e dispatch leem daqui.
STEPS='specify-prompt specify clarify plan-prompt plan tasks analyze trace'

step_valid() {  # name → rc 0 se é passo conhecido
  case " $STEPS " in *" ${1:-} "*) return 0 ;; *) return 1 ;; esac
}

step_index() {  # name → índice 1-based em stdout, rc 1 se desconhecido
  local i=0 s
  for s in $STEPS; do
    i=$((i + 1))
    [ "$s" = "${1:-}" ] && { printf '%s' "$i"; return 0; }
  done
  return 1
}

steps_from() {  # name → esse passo e todos a jusante, separados por espaço
  local out="" hit="" s
  for s in $STEPS; do
    [ "$s" = "${1:-}" ] && hit=1
    [ -n "$hit" ] && out="$out $s"
  done
  printf '%s' "${out# }"
}

step_type() {  # name → bridge|speckit|clarify|trace|unknown
  case "${1:-}" in
    specify-prompt|plan-prompt)   printf 'bridge' ;;
    specify|plan|tasks|analyze)   printf 'speckit' ;;
    clarify)                      printf 'clarify' ;;
    trace)                        printf 'trace' ;;
    *)                            printf 'unknown' ;;
  esac
}

# --- Leitores do file-drop (funções puras) ---------------------------------
# next.txt: o comando /speckit.* que a ponte gravou. Válido = existe, não-vazio,
# 1ª linha começa com /speckit. — daí ler o conteúdo INTEIRO (o prompt do
# specify/plan é prosa longa e pode ter várias linhas). Ausente/vazio/inválido →
# vazio, que é a falha DETECTÁVEL do design (não um parser que pega string errada
# em silêncio).
read_next() {  # file → comando inteiro se válido, senão vazio
  local first
  [ -f "${1:-}" ] || return 0
  [ -s "${1:-}" ] || return 0
  first="$(head -n1 -- "$1" 2>/dev/null)"
  case "$first" in
    /speckit.*) cat -- "$1" ;;
    *)          : ;;
  esac
  return 0
}

# O next.txt dobra como sinal de "ponte terminou": após cada `result`, se
# read_next não é vazio, o passo de ponte está feito (design §Sessão e extração).
next_ready() {  # file → rc 0 se read_next não é vazio
  [ -n "$(read_next "${1:-}")" ]
}

# signal.txt: OK | SUFFICIENCY_STOP. Âncora `^…$` — o sinal ocupa a linha inteira,
# não conta citado em prosa. tail -n1: se houver mais de um, o último vence.
read_signal() {  # file → OK|SUFFICIENCY_STOP|vazio
  [ -f "${1:-}" ] || return 0
  grep -oE '^(OK|SUFFICIENCY_STOP)$' -- "$1" 2>/dev/null | tail -n1
  return 0
}

# --- Classificador do `analyze` (função pura de texto) ---------------------
# Achado de severidade CRÍTICA no relatório do /speckit.analyze → parada (design
# #2). Casa a severidade como MARCADOR (célula de tabela `| CRITICAL |`, rótulo
# `Severity: CRITICAL`, ou `**CRITICAL**`), nunca a palavra solta em prosa —
# senão "a critical part" abortaria um analyze limpo. Bilíngue: o analyze alterna
# pt/en. Primeiro corte; a Task 15 endurece contra turnos reais.
classify_analyze() {  # texto do turno → critico|limpo
  if printf '%s' "${1:-}" | grep -qiE \
    '(\|[[:space:]]*(CRITICAL|CRÍTICO|CRÍTICA)[[:space:]]*\|)|(severidade?e?[[:space:]]*:[[:space:]]*(CRITICAL|CRÍTICO|CRÍTICA))|(severity[[:space:]]*:[[:space:]]*(CRITICAL|CRÍTICO|CRÍTICA))|(\*\*(CRITICAL|CRÍTICO|CRÍTICA)\*\*)'; then
    printf 'critico'
  else
    printf 'limpo'
  fi
}

# --- Resolução do check-prd.sh + detecção de vazamento de stack ------------
# O par check-prd.sh+quality-rules.md é a fronteira curada da HARNESS, resolvido
# da instalação da harness — nunca de --repo (a denylist não é do produto-alvo).
# Ordem: override explícito, depois o cache do plugin marketplace. Confirma que o
# quality-rules.md sibling resolve (references-case ao lado, ou repo-case ../assets).
resolve_check_prd() {  # → path do check-prd.sh, ou vazio+rc1
  local c d
  if [ -n "${SPECKIT_E2E_CHECK_PRD:-}" ]; then
    [ -f "$SPECKIT_E2E_CHECK_PRD" ] && { printf '%s' "$SPECKIT_E2E_CHECK_PRD"; return 0; }
    return 1
  fi
  for c in "$HOME/.claude/plugins/marketplaces/zion-build-prd/scripts/check-prd.sh"; do
    [ -f "$c" ] || continue
    d="$(dirname "$c")"
    if [ -f "$d/quality-rules.md" ] || [ -f "$d/../assets/quality-rules.md" ]; then
      printf '%s' "$c"; return 0
    fi
  done
  return 1
}

# Formato do achado de stack: `<LABEL>:<n>: stack — "<termo>" (...)` (check-prd.sh
# modo specify, linhas 75-91). O `: stack — ` é a marca estável.
is_stack_finding() {  # linha de saída do check-prd.sh → rc 0 se é achado de stack
  case "${1:-}" in *': stack — '*) return 0 ;; *) return 1 ;; esac
}

# Roda check-prd.sh em modo specify sobre o arquivo e mantém SÓ os achados de
# stack (ignora rf-cobertos-ausente, que não é parada curada). Serve tanto para o
# next.txt (prompt do specify) quanto para o spec.md gerado. Determinístico: o
# script já é a fonte curada da fronteira (design §Protocolo).
stack_findings() {  # check-prd-path  file → linhas de achado stack, ou vazio
  bash "${1:?}" specify "${2:?}" 2>/dev/null | grep -F ': stack — '
  return 0
}

# --- Custo e teto de gate (funções puras) ----------------------------------
add_cost() {  # a b → a+b com 6 casas
  awk -v a="$1" -v b="$2" 'BEGIN{printf "%.6f", a+b}'
}

# total_cost_usd é ACUMULADO da sessão (speckit-clarify-loop:368-374): dentro de
# um passo, o custo é o ÚLTIMO valor. Entre passos (cada um um processo/sessão
# nova), o main_loop SOMA via add_cost.
pick_cost() {  # linha-jsonl  custo-atual → custo do passo até aqui
  local c
  c="$(printf '%s' "${1:-}" | jq -r '.total_cost_usd // empty' 2>/dev/null)"
  case "$c" in
    ''|null) printf '%s' "${2:-0}" ;;
    *)       printf '%s' "$c" ;;
  esac
  return 0
}

# Teto global somado (#9). ceiling vazio = sem limite. Estritamente maior: bater
# o teto exato não aborta.
cost_exceeded() {  # total  ceiling → rc 0 se total > ceiling
  [ -n "${2:-}" ] || return 1
  awk -v t="${1:-0}" -v c="$2" 'BEGIN{exit !(t > c)}'
}

# Teto de "confirma, siga" por sessão de ponte (design #1/§Sessão): nunca fica
# pendurado num gate que se repete. Espelha o miss_action do clarify.
gate_action() {  # nº de confirmações já injetadas → confirma|aborta
  if [ "${1:-0}" -lt "$GATE_MAX" ]; then printf 'confirma'; else printf 'aborta'; fi
}

# --- Estado, retomada e limpeza a jusante ----------------------------------
# Retomada idempotente (design #6): specify é o caso crítico — re-rodá-lo recria a
# branch e regenera o spec.md, apagando as edições do clarify. Por isso specify
# pula se o spec.md JÁ EXISTE, mesmo sem marcador. Os demais pulam por marcador.
should_skip() {  # step  is_done(sim|nao)  artifact(sim|nao|na) → sim|nao
  case "${1:-}" in
    specify)
      if [ "${2:-nao}" = sim ] || [ "${3:-na}" = sim ]; then printf sim; else printf nao; fi ;;
    *)
      if [ "${2:-nao}" = sim ]; then printf sim; else printf nao; fi ;;
  esac
}

# --from limpa os marcadores do passo e de tudo a jusante. Esta função pura decide,
# por linha do state, se ela sobrevive: linha que não é `done=` sempre sobrevive;
# `done=<s>` sobrevive só se <s> NÃO está em steps_from(from).
state_keep_line() {  # linha  from-step → rc 0 se a linha sobrevive
  case "${1:-}" in
    done=*) ;;
    *) return 0 ;;
  esac
  local s="${1#done=}" f d
  for d in $(steps_from "${2:-}"); do
    [ "$d" = "$s" ] && return 1
  done
  return 0
}

# Impuras: o state é key=value, uma por linha, em $STATE_FILE.
state_mark_done() { printf 'done=%s\n' "${1:-}" >> "$STATE_FILE"; }
state_is_done()   { grep -qxF "done=${1:-}" "$STATE_FILE" 2>/dev/null; }
state_get()       { grep -m1 "^${1:-}=" "$STATE_FILE" 2>/dev/null | sed "s/^${1:-}=//"; }
state_set() {  # chave valor — substitui a linha se existe, senão anexa
  local k="${1:-}" v="${2:-}" tmp
  tmp="$(mktemp)"
  grep -v "^${k}=" "$STATE_FILE" 2>/dev/null > "$tmp" || true
  printf '%s=%s\n' "$k" "$v" >> "$tmp"
  mv -- "$tmp" "$STATE_FILE"
}
state_clear_from() {  # from-step — apaga done= do passo e a jusante
  local from="${1:-}" tmp line
  [ -f "$STATE_FILE" ] || return 0
  tmp="$(mktemp)"
  while IFS= read -r line || [ -n "$line" ]; do
    state_keep_line "$line" "$from" && printf '%s\n' "$line" >> "$tmp"
  done < "$STATE_FILE"
  mv -- "$tmp" "$STATE_FILE"
}

# --- Monitor: copiado verbatim do speckit-clarify-loop --------------------
ratelimit_fatal() {  # status → 0 se a rodada deve abortar
  case "${1:-?}" in
    allowed|allowed_*) return 1 ;;
    *)                 return 0 ;;
  esac
}

# --- Leitura das negações de permissão (funções puras de texto) -------------
# A guarda original abortava a rodada diante de QUALQUER permission_denial, com
# a justificativa de que a rodada "gravaria spec pela metade". A justificativa
# vale para a família que escreve: negar um `Edit` no meio de uma sequência de
# edições deixa o spec com metade das mudanças aplicadas. Não vale para leitura.
#
# Em 2026-07-21 isso custou duas rodadas inteiras (US$ 1,75 e US$ 1,79) em
# zion-mermaid-editor-app: o que foi negado era um `grep` de listar cabeçalhos,
# a skill contornou, a rodada terminou com a pergunta completa e `is_error`
# false — e o script jogou tudo fora assim mesmo.
#
# `Bash` fica FORA da lista de mutantes de propósito, e a razão merece estar
# escrita: uma chamada negada não executou, então ela própria não gravou nada. O
# risco de spec meio escrito nasce da sequência de `Edit` que a skill usa para
# atualizar o spec, e é essa sequência que a guarda protege.
MUTANTES='Edit Write MultiEdit NotebookEdit'
denied_tools() {  # linha-jsonl → nomes das ferramentas negadas, separados por espaço
  printf '%s' "${1:-}" \
    | jq -r '[(.permission_denials // [])[] | .tool_name // "?"] | join(" ")' 2>/dev/null
  return 0
}

mutating_only() {  # lista de nomes → só as que escrevem, na mesma ordem
  local out="" t m
  for t in ${1:-}; do
    for m in $MUTANTES; do
      if [ "$t" = "$m" ]; then out="$out $t"; break; fi
    done
  done
  printf '%s' "${out# }"
  return 0
}
# --- Monitor: primitivas de formatação -------------------------------------
# Dois perfis. `tty` usa símbolos e ANSI; `plain` usa rótulos ASCII e nada de
# escape — porque o round-NN.log tem que continuar legível seis meses depois,
# e arquivo com sequência ANSI dentro é arquivo que ninguém relê.
MON_IND='         '   # 9 colunas: a indentação de continuação, nos dois perfis

mon_marker() {  # perfil kind → marcador (no perfil plain, já com 8 colunas)
  case "${1:-}:${2:-}" in
    tty:tool)       printf '⚙' ;;
    tty:text)       printf '◆' ;;
    tty:you)        printf '▸' ;;
    tty:thinking)   printf '·' ;;
    tty:ok)         printf '✓' ;;
    tty:warn)       printf '⚠' ;;
    tty:info)       printf 'ⓘ' ;;
    plain:tool)     printf '[tool]  ' ;;
    plain:text)     printf '[claude]' ;;
    plain:you)      printf '[você]  ' ;;
    plain:thinking) printf '[...]   ' ;;
    plain:ok)       printf '[ok]    ' ;;
    plain:warn)     printf '[!]     ' ;;
    plain:info)     printf '[nota]  ' ;;
    *)              printf '?' ;;
  esac
}

mon_head() {  # clock marcador corpo
  printf '  %s  %s  %s\n' "${1:-}" "${2:-}" "${3:-}"
}

mon_paint() {  # perfil cor texto
  if [ "${1:-}" != tty ]; then printf '%s' "${3:-}"; return 0; fi
  local c
  case "${2:-}" in
    dim)  c=$'\033[2m' ;;
    bold) c=$'\033[1m' ;;
    red)  c=$'\033[31m' ;;
    *)    printf '%s' "${3:-}"; return 0 ;;
  esac
  printf '%s%s\033[0m' "$c" "${3:-}"
}

mon_trunc() {  # texto largura
  local t="${1:-}" w="${2:-80}"
  [ "$w" -ge 8 ] || w=8
  if [ "${#t}" -le "$w" ]; then printf '%s' "$t"; return 0; fi
  printf '%s…' "${t:0:$((w - 1))}"
}

# Dobra a prosa e indenta em 9 colunas. Tabelas markdown e cercas de código
# escapam da dobra de propósito: quebrar a tabela de opções destrói exatamente
# a informação que se quer ler. Se estourar a largura, estoura.
mon_fold() {  # largura total; stdin → stdout
  local w=$(( ${1:-80} - 9 ))
  [ "$w" -ge 20 ] || w=20
  local l
  while IFS= read -r l || [ -n "$l" ]; do
    case "$l" in
      '')        printf '\n' ;;
      '|'*|'```'*) printf '%s%s\n' "$MON_IND" "$l" ;;
      *)         printf '%s\n' "$l" | fold -s -w "$w" \
                   | sed -e "s/^/$MON_IND/" -e 's/[[:space:]]*$//' ;;
    esac
  done
  return 0
}

# Resumo de um tool_use: comando para Bash, basename para quem tem file_path,
# e um genérico de primeira chave para o resto (nenhuma ferramenta fica muda).
# Só o primeiro tool_use da linha é resumido — perder uma chamada de ferramenta
# é aceitável; perder prosa não é, e por isso a prosa tem precedência em
# event_kind.
tool_summary() {  # linha-jsonl → NOME<TAB>RESUMO
  printf '%s' "${1:-}" | jq -r '
    ([.message.content[]? | select(.type=="tool_use")] | first) as $t
    | if $t == null then empty else
        ($t.input // {}) as $i
        | [ ($t.name // "?"),
            ( if   $i.command   then ($i.command | gsub("\\s+"; " "))
              elif $i.file_path then ($i.file_path | split("/") | last)
              elif $i.pattern   then $i.pattern
              else (($i | keys | first) as $k
                    | if $k == null then "" else "\($k)=\($i[$k] | tostring)" end)
              end ) ]
        | @tsv
      end' 2>/dev/null
  return 0
}

# --- Monitor: leitura de eventos -------------------------------------------
# Traduz uma linha do stream JSONL num rótulo. Função pura: sem I/O além do
# stdout, sem estado global. Qualquer linha que o jq não digira cai em
# `nothing` — o monitor é aditivo e jamais derruba a rodada.
#
# Precedência dentro de uma linha `assistant`: text > tool_use > thinking.
# No stream observado toda linha trazia um único bloco, mas se a API um dia
# agrupar blocos, perder a prosa seria a única falha inaceitável.
event_kind() {
  local line="${1:-}" typ types st
  typ="$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)"
  case "$typ" in
    result)
      printf 'result\n'; return 0 ;;
    rate_limit_event)
      st="$(printf '%s' "$line" | jq -r '.rate_limit_info.status // "?"' 2>/dev/null)"
      if [ "$st" = "allowed" ]; then printf 'nothing\n'; else printf 'ratelimit\n'; fi
      return 0 ;;
    assistant)
      types="$(printf '%s' "$line" | jq -r '[.message.content[]?.type] | join(" ")' 2>/dev/null)"
      case " $types " in
        *' text '*)     printf 'text\n' ;;
        *' tool_use '*) printf 'tool\n' ;;
        *' thinking '*) printf 'thinking\n' ;;
        *)              printf 'nothing\n' ;;
      esac
      return 0 ;;
    *)
      printf 'nothing\n'; return 0 ;;
  esac
}

# Suprime `pensando…` repetido. Note que o kind anterior é o último kind
# EFETIVO — eventos que não rendem linha (system/*, tool_result) não o mexem,
# de modo que thinking · ruído · thinking conta como um só arroubo de reflexão.
dedup_kind() {  # kind-anterior  kind → kind efetivo
  if [ "${2:-}" = thinking ] && [ "${1:-}" = thinking ]; then
    printf 'nothing\n'
  else
    printf '%s\n' "${2:-nothing}"
  fi
}

# --- Monitor: renderização --------------------------------------------------
# (perfil, largura, clock, kind, linha) → narração. Pura: o relógio chega
# pronto, nada de estado mutável. É a única função que sabe como a saída se
# parece, e por isso a única que precisa mudar se a apresentação mudar.
render_line() {  # perfil largura clock kind linha
  local p="${1:-plain}" w="${2:-80}" clock="${3:-00:00}" kind="${4:-nothing}" line="${5:-}"
  local body mark prefix tsv name summary st

  case "$kind" in
    thinking)
      mon_head "$clock" "$(mon_marker "$p" thinking)" "$(mon_paint "$p" dim 'pensando…')"
      ;;
    tool)
      tsv="$(tool_summary "$line")"
      [ -n "$tsv" ] || return 0
      name="${tsv%%$'\t'*}"
      summary="${tsv#*$'\t'}"
      [ "$summary" != "$tsv" ] || summary=""
      # Colunas consumidas por "  CLOCK  MARCADOR  ": 2+5+2+largura+2. Sai do
      # próprio marcador em vez de uma tabela paralela: `⚙` dá 12 e `[tool]  `
      # dá 19, os mesmos números da função que isto substitui. `${#}` conta
      # caractere e não byte sob locale UTF-8 — a mesma premissa que mon_trunc
      # já faz ao cortar prosa acentuada, não uma premissa nova.
      mark="$(mon_marker "$p" tool)"
      prefix=$(( 2 + 5 + 2 + ${#mark} + 2 ))
      body="$(printf '%-8s %s' "$name" "$summary")"
      body="$(mon_trunc "$body" $(( w - prefix )))"
      mon_head "$clock" "$mark" "$(mon_paint "$p" dim "$body")"
      ;;
    text)
      mon_head "$clock" "$(mon_marker "$p" text)" 'claude'
      printf '%s' "$line" \
        | jq -r '[.message.content[]? | select(.type=="text") | .text] | join("\n\n")' 2>/dev/null \
        | mon_fold "$w"
      ;;
    ratelimit)
      st="$(printf '%s' "$line" | jq -r '.rate_limit_info.status // "?"' 2>/dev/null)"
      mon_head "$clock" "$(mon_marker "$p" warn)" "$(mon_paint "$p" red "rate limit: $st")"
      ;;
    *)
      # nothing e result não rendem linha. O rodapé da rodada é emitido pelo
      # motor (emit_note), que é quem conhece o contador de yes e o delta do
      # spec; e a prosa do `.result` é a mesma do último bloco assistant, que
      # já foi impressa — reimprimi-la duplicaria a pergunta inteira.
      return 0
      ;;
  esac
  return 0
}

# --- Monitor: cola com estado -----------------------------------------------
# O único lugar do monitor que fala com o mundo: relógio, destinos e a memória
# do último kind. As três funções acima permanecem puras justamente porque tudo
# que é impuro está aqui.

mon_setup() {  # decide perfil e largura, uma vez, no arranque
  if [ -t 1 ]; then
    MON_PROFILE=tty
    MON_WIDTH="$(tput cols 2>/dev/null || printf '80')"
    case "$MON_WIDTH" in ''|*[!0-9]*) MON_WIDTH=80 ;; esac
    [ "$MON_WIDTH" -le 100 ] || MON_WIDTH=100
    [ "$MON_WIDTH" -ge 40 ] || MON_WIDTH=40
  else
    MON_PROFILE=plain
    MON_WIDTH=80
  fi
  return 0
}

mon_clock() { printf '%02d:%02d' $(( SECONDS / 60 )) $(( SECONDS % 60 )); }

mon_step_start() {  # caminho do round-NN.log
  STEP_LOG="${1:-}"
  LAST_KIND=""
  SECONDS=0
  [ -z "$STEP_LOG" ] || : > "$STEP_LOG"
  return 0
}

# O log em arquivo recebe SEMPRE perfil plain com largura 80 — daí a prosa ser
# renderizada duas vezes no TTY. É baratíssimo, e evita ter que arrancar ANSI
# com sed no caminho de escrita.
emit_event() {  # linha-jsonl
  local line="${1:-}" kind clock
  kind="$(event_kind "$line")"
  kind="$(dedup_kind "$LAST_KIND" "$kind")"
  [ "$kind" = nothing ] && return 0
  LAST_KIND="$kind"
  clock="$(mon_clock)"
  [ "$QUIET" -eq 1 ] || render_line "$MON_PROFILE" "$MON_WIDTH" "$clock" "$kind" "$line"
  [ -z "$STEP_LOG" ] || render_line plain 80 "$clock" "$kind" "$line" >> "$STEP_LOG"
  return 0
}

# Linhas que nascem no motor, não no stream: o eco do `yes`, o rodapé da
# rodada, os avisos de aborto.
emit_note() {  # kind texto
  local kind="${1:-text}" text="${2:-}" clock color
  case "$kind" in
    you)  color=bold ;;
    warn) color=red ;;
    info) color=bold ;;
    *)    color=none ;;
  esac
  clock="$(mon_clock)"
  [ "$QUIET" -eq 1 ] || \
    mon_head "$clock" "$(mon_marker "$MON_PROFILE" "$kind")" "$(mon_paint "$MON_PROFILE" "$color" "$text")"
  [ -z "$STEP_LOG" ] || \
    mon_head "$clock" "$(mon_marker plain "$kind")" "$text" >> "$STEP_LOG"
  return 0
}

# Estrutura (cabeçalho de rodada): sem relógio, e sobrevive ao --quiet — é o
# mínimo que diz "ainda estou vivo" quando a narração está calada.
emit_rule() {  # texto
  printf '%s\n' "${1:-}"
  [ -z "$STEP_LOG" ] || printf '%s\n' "${1:-}" >> "$STEP_LOG"
  return 0
}
# --- Motor de sessão (run_step) --------------------------------------------
# Uma mensagem de usuário JSONL no fd 3 (speckit-clarify-loop:859-862).
send_user() {  # texto → mensagem de usuário no fd 3
  jq -cn --arg t "$1" \
    '{type:"user",message:{role:"user",content:[{type:"text",text:$t}]}}' >&3
}

# Saídas do passo, por escopo dinâmico (o dispatch por tipo as escreve).
STEP_OUTCOME=""; STEP_ABORT=""; STEP_COST=0; STEP_LAST_TEXT=""; STEP_STOP_WHY=""
GATE_COUNT=0   # confirmações injetadas na sessão de ponte corrente

# run_step: um processo `claude` para o passo. `$1` = nome do passo. As três
# coisas que variam por passo — allowedTools, --append-system-prompt e a
# mensagem inicial — vêm de step_args/step_appendix/step_initial (Tasks 9-12).
run_step() {
  local step="$1" tag idx
  idx="$(step_index "$step")"; tag="$(printf 'step-%02d' "$idx")"
  local log="$STATE_DIR/$tag.jsonl" err="$log.err" in="$WORK/in-$idx.fifo"

  STEP_OUTCOME=""; STEP_ABORT=""; STEP_COST=0; STEP_LAST_TEXT=""; STEP_STOP_WHY=""
  GATE_COUNT=0

  mkfifo "$in" || { STEP_OUTCOME=aborto; STEP_ABORT="mkfifo falhou"; return; }
  : > "$log"; : > "$err"

  # Args base + os específicos do passo (Tasks 9-12 preenchem step_args/appendix).
  local -a args=(
    -p --input-format stream-json --output-format stream-json --verbose
    --permission-mode acceptEdits
  )
  step_args "$step"; args+=( "${STEP_ARGS[@]}" )
  local appendix; appendix="$(step_appendix "$step")"
  [ -z "$appendix" ] || args+=( --append-system-prompt "$appendix" )

  ( cd "$REPO" && exec timeout -s TERM "$STEP_TIMEOUT" claude "${args[@]}" ) \
    < "$in" > "$log" 2> "$err" &
  local cpid=$!
  exec 3<> "$in"

  send_user "$(step_initial "$step")"

  local line typ status iserr denied mutantes txt
  while IFS= read -r line; do
    emit_event "$line"
    typ="$(printf '%s' "$line" | jq -r '.type // empty' 2>/dev/null)" || continue

    if [ "$typ" = "rate_limit_event" ]; then
      status="$(printf '%s' "$line" | jq -r '.rate_limit_info.status // "?"')"
      if ratelimit_fatal "$status"; then
        STEP_OUTCOME=aborto
        STEP_ABORT="rate limit com status=$status — cota esgotada, não insisto"
        break
      fi
      continue
    fi

    [ "$typ" = "result" ] || continue

    iserr="$(printf '%s' "$line" | jq -r '.is_error // false')"
    denied="$(denied_tools "$line")"
    mutantes="$(mutating_only "$denied")"
    STEP_COST="$(pick_cost "$line" "$STEP_COST")"

    if [ "$iserr" = "true" ]; then
      STEP_OUTCOME=aborto; STEP_ABORT="result com is_error=true (ver $log)"; break
    fi
    if [ -n "$mutantes" ] && [ "$DRY_RUN" -eq 0 ]; then
      STEP_OUTCOME=aborto
      STEP_ABORT="permissão negada em ferramenta que escreve ($mutantes) — passo gravaria pela metade"
      break
    fi
    [ -z "$denied" ] || [ -n "$mutantes" ] \
      || emit_note warn "permissão negada, passo segue: $denied"

    txt="$(printf '%s' "$line" | jq -r '.result // ""')"
    STEP_LAST_TEXT="$txt"

    # Dispatch por tipo — decide se o passo terminou, se injeta algo, ou se para.
    # Cada handler pode setar STEP_OUTCOME (para dar break) via a variável global.
    case "$(step_type "$step")" in
      bridge)  handle_turn_bridge  "$txt" ;;
      speckit) handle_turn_speckit "$txt" ;;
      trace)   handle_turn_trace   "$txt" ;;
    esac
    [ -z "$STEP_OUTCOME" ] || break
  done < <(exec 3>&-; tail -n +1 -f --pid="$cpid" --sleep-interval=0.2 "$log")

  exec 3>&-              # fecha o stdin do claude → o processo sai → é o /clear
  wait "$cpid" 2>/dev/null
  rm -f "$in"

  if [ -z "$STEP_OUTCOME" ]; then
    STEP_OUTCOME=aborto
    STEP_ABORT="o processo claude terminou sem passo classificável (ver $err)"
  fi
  [ "$STEP_OUTCOME" != aborto ] || emit_note warn "aborto: $STEP_ABORT"
}

